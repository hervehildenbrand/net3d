# NetBox connection (server-side only — never exposed to the browser)
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=changeme
# Set to "false" if NetBox uses a self-signed/internal CA certificate
NETBOX_TLS_VERIFY=true
# Backend listen port
PORT=3001
# Persist the NetBox cache to disk so a server restart doesn't re-warm from cold
# (default on). Set to "0" to disable. CACHE_DIR overrides the location
# (default: packages/server/.cache/net3d, keyed per NetBox instance).
CACHE_PERSIST=1
# CACHE_DIR=/var/cache/net3d
