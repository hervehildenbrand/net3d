# Source of truth: "netbox" (default) or "infrahub". Selects which backend the
# server reads from; all connection details below are server-side only and never
# exposed to the browser.
SOT_BACKEND=netbox

# NetBox connection (used when SOT_BACKEND=netbox)
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=changeme
# Set to "false" if NetBox uses a self-signed/internal CA certificate
NETBOX_TLS_VERIFY=true

# Infrahub connection (used when SOT_BACKEND=infrahub)
# INFRAHUB_URL=https://infrahub.example.com
# INFRAHUB_TOKEN=changeme
# INFRAHUB_BRANCH=main
# INFRAHUB_TLS_VERIFY=true
# Backend listen port
PORT=3001
# Bind address. Defaults to 127.0.0.1 (loopback). Containers behind a reverse
# proxy set HOST=0.0.0.0 to be reachable.
# HOST=127.0.0.1
# Optional shared-secret guard. When set, every /api/* route (except /api/health)
# requires `Authorization: Bearer <token>`. Leave unset for an open read-only demo;
# a browser cannot hold a secret, so use this for API clients or have an
# authenticating reverse proxy inject the header.
# NET3D_API_TOKEN=
# Server log level (pino): fatal|error|warn|info|debug|trace. Default: info.
# LOG_LEVEL=info
# Persist the cache to disk so a server restart doesn't re-warm from cold
# (default on). Set to "0" to disable. CACHE_DIR overrides the location
# (default: packages/server/.cache/net3d, keyed per backend instance).
CACHE_PERSIST=1
# CACHE_DIR=/var/cache/net3d

# Floor-plan editor (user-edited rack layouts). OFF by default: layout writes
# return 403 and the "Edit layout" button is hidden, so the deployment stays a
# read-only viewer. Set LAYOUT_EDIT=1 to allow edits (and, behind the hardened
# nginx, add a PUT/DELETE carve-out for /api/layouts/*). Layouts are stored as
# one JSON file per site under LAYOUT_DIR (default packages/server/.data/net3d-layouts)
# — keep it on a persistent volume so they survive redeploys. Backend-agnostic:
# served via /api regardless of SOT_BACKEND, so both dual-stack instances share one.
# LAYOUT_EDIT=0
# LAYOUT_DIR=/var/lib/net3d/layouts
